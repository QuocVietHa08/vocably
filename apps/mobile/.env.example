# Backend API URL — all OpenAI calls are proxied through this server
# Set this to the deployed URL of apps/web (e.g. https://your-app.vercel.app)
# The server must have OPENAI_API_KEY set in its environment (NOT NEXT_PUBLIC_)
EXPO_PUBLIC_BACKEND_URL=https://your-app.vercel.app

# ─── Supabase (Authentication) ────────────────────────────────────
# 1. Create a project at https://supabase.com/dashboard
# 2. Go to Settings → API to get these values
# 3. Enable Google & Apple OAuth providers under Authentication → Providers
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── RevenueCat (In-App Purchases / Paywall) ─────────────────────
# 1. Create a project at https://app.revenuecat.com
# 2. Go to Project Settings → API Keys
# 3. Create products in App Store Connect / Google Play Console:
#    - Monthly: $5.99/month
#    - Yearly:  $49.99/year (≈ $4.17/month)
# 4. Create an Offering in RevenueCat with both packages
# 5. Add an entitlement called "pro"
EXPO_PUBLIC_RC_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
